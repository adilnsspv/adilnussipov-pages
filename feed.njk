---
permalink: /feed.xml
eleventyExcludeFromCollections: true
---
<?xml version="1.0" encoding="utf-8"?>
<rss version="2.0" xmlns:atom="http://www.w3.org/2005/Atom">
  <channel>
    <title>Adil Nussipov</title>
    <link>https://adilnussipov.com</link>
    <description>Writing by Adil Nussipov</description>
    <language>en</language>
    <atom:link href="https://adilnussipov.com/feed.xml" rel="self" type="application/rss+xml"/>
    {% for post in collections.posts %}
    <item>
      <title>{{ post.data.title | escape }}</title>
      <link>https://adilnussipov.com{{ post.url }}</link>
      <guid>https://adilnussipov.com{{ post.url }}</guid>
      <pubDate>{{ post.date | rssDate }}</pubDate>
      {% if post.data.description %}<description>{{ post.data.description | escape }}</description>{% endif %}
    </item>
    {% endfor %}
  </channel>
</rss>
