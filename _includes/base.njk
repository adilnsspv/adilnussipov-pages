<!doctype html>
<html lang="en">
<head>
  <meta charset="utf-8">
  <meta name="viewport" content="width=device-width, initial-scale=1">
  <title>{% if title %}{{ title }} — {% endif %}Adil Nussipov</title>
  <meta name="description" content="{% if description %}{{ description }}{% else %}Writing by Adil Nussipov.{% endif %}">
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link rel="stylesheet" href="https://fonts.googleapis.com/css2?family=Source+Serif+4:ital,opsz,wght@0,8..60,400;0,8..60,700;1,8..60,400;1,8..60,700&display=swap">
  <link rel="stylesheet" href="/css/style.css">
  <script>
    if (CSS.highlights) {
      const s = document.createElement('style');
      s.textContent = '::selection{background:transparent!important;color:inherit!important}';
      document.head.appendChild(s);
      const h = new Highlight();
      CSS.highlights.set('sel', h);
      document.addEventListener('selectionchange', function () {
        h.clear();
        const sel = getSelection();
        if (sel && sel.rangeCount && !sel.getRangeAt(0).collapsed)
          h.add(sel.getRangeAt(0));
      });
    }
  </script>
  <link rel="icon" type="image/png" href="/images/favicon-32.png" sizes="32x32">
  <link rel="apple-touch-icon" sizes="180x180" href="/images/favicon-180.png">
</head>
<body>
  <div class="container">
    <header>
      <div class="header-inner">
        <a href="/" class="site-logo-link">
          <img src="/images/avatar.png" alt="Adil Nussipov" class="site-avatar">
          <span class="site-name">Adil Nussipov</span>
        </a>
        <nav>
          <a href="/writing/">Writing</a>
          <a href="/reading/">Reading</a>
          <a href="/about/">About</a>
        </nav>
      </div>
    </header>
    <main>
      {{ content | safe }}
    </main>
    <footer>
      <p>Adil Nussipov &mdash; <a href="https://adilnussipov.com">adilnussipov.com</a></p>
    </footer>
  </div>
</body>
</html>
