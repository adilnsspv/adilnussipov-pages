<!doctype html>
<html lang="en">
<head>
  <meta charset="utf-8">
  <meta name="viewport" content="width=device-width, initial-scale=1">
  <title>{% if title %}{{ title }} — {% endif %}Adil Nussipov</title>
  <meta name="description" content="{% if description %}{{ description }}{% else %}Writing by Adil Nussipov.{% endif %}">
  <link rel="stylesheet" href="/css/style.css">
  <link rel="icon" type="image/png" href="/images/favicon-32.png" sizes="32x32">
  <link rel="apple-touch-icon" sizes="180x180" href="/images/favicon-180.png">
</head>
<body>
  <div class="container">
    <header>
      <div class="header-inner">
        <a href="/" class="site-logo-link">
          <img src="/images/avatar.png" alt="Adil Nussipov" class="site-avatar">
          <span class="site-name">Adil Nussipov</span>
        </a>
        <nav>
          <a href="/writing/">Writing</a>
          <a href="/about/">About</a>
        </nav>
      </div>
    </header>
    <main>
      {{ content | safe }}
    </main>
    <footer>
      <p>Adil Nussipov &mdash; <a href="https://adilnussipov.com">adilnussipov.com</a></p>
    </footer>
  </div>
</body>
</html>
