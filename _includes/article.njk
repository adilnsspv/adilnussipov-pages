---
layout: base.njk
---
<article class="article-content h-entry">
  <header class="article-header">
    <span class="article-date dt-published">{{ page.date | postDate }}</span>
    <h1 class="p-name">{{ title }}</h1>
    {% if description %}
    <p class="article-subtitle p-summary">{{ description }}</p>
    {% endif %}
  </header>
  <div class="article-body e-content">
    {{ content | safe }}
  </div>
  {% set backlinks = page.url | getBacklinks %}
  {% if backlinks.length %}
  <section class="referenced-by">
    <p class="section-label">Referenced by</p>
    <ul>
      {% for link in backlinks %}
      <li><a href="{{ link.url }}">{{ link.title }}</a></li>
      {% endfor %}
    </ul>
  </section>
  {% endif %}
  <footer class="article-footer">
    <a href="/writing/">&larr; All writing</a>
  </footer>
</article>
